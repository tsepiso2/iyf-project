import { useState, useEffect } from 'react';
import { useNavigate } from 'react-router-dom';
import { useAuth } from '@/context/AuthContext';
import { LogOut, MessageSquare, Save, Eye, Link as LinkIcon, Download, FileText, AlertCircle } from 'lucide-react';
import { useToast } from '@/components/ui/use-toast';

interface Submission {
  id: string;
  studentName: string;
  studentEmail: string;
  files: Array<{ name: string; type: string }>;
  links?: Array<{ url: string; title: string }>;
  submittedAt: string;
  marks?: number;
  feedback?: string;
}

export default function AdminSubmissions() {
  const [submissions, setSubmissions] = useState<Submission[]>([]);
  const [selectedSubmission, setSelectedSubmission] = useState<Submission | null>(null);
  const [marks, setMarks] = useState('');
  const [feedback, setFeedback] = useState('');
  const [isSaving, setIsSaving] = useState(false);
  const [selectedFile, setSelectedFile] = useState<{ name: string; type: string } | null>(null);
  const { user, logout } = useAuth();
  const navigate = useNavigate();
  const { toast } = useToast();

  useEffect(() => {
    if (!user || user.role !== 'admin') {
      navigate('/');
    }
  }, [user, navigate]);

  useEffect(() => {
    const stored = localStorage.getItem('submissions');
    if (stored) {
      const subs = JSON.parse(stored);
      setSubmissions(subs);
      if (subs.length > 0) {
        setSelectedSubmission(subs[0]);
        setMarks(subs[0].marks?.toString() || '');
        setFeedback(subs[0].feedback || '');
      }
    }
  }, []);

  const handleSubmissionSelect = (submission: Submission) => {
    setSelectedSubmission(submission);
    setMarks(submission.marks?.toString() || '');
    setFeedback(submission.feedback || '');
  };

  const handleSaveMarks = async () => {
    if (!selectedSubmission) return;

    const marksNum = parseInt(marks);
    if (isNaN(marksNum) || marksNum < 0 || marksNum > 100) {
      toast({ title: 'Error', description: 'Please enter marks between 0 and 100', variant: 'destructive' });
      return;
    }

    if (!feedback.trim()) {
      toast({ title: 'Error', description: 'Please add feedback for the student', variant: 'destructive' });
      return;
    }

    setIsSaving(true);
    try {
      const updatedSubmissions = submissions.map((sub) =>
        sub.id === selectedSubmission.id
          ? { ...sub, marks: marksNum, feedback }
          : sub
      );
      localStorage.setItem('submissions', JSON.stringify(updatedSubmissions));
      setSubmissions(updatedSubmissions);

      const updated = updatedSubmissions.find((s) => s.id === selectedSubmission.id);
      if (updated) {
        setSelectedSubmission(updated);
      }

      toast({ title: 'Success!', description: 'Marks and feedback saved successfully!' });
    } catch (error) {
      toast({ title: 'Error', description: 'Failed to save marks', variant: 'destructive' });
    } finally {
      setIsSaving(false);
    }
  };

  const handleLogout = () => {
    logout();
    toast({ description: 'Logged out successfully' });
    navigate('/');
  };

  const downloadFile = (fileName: string) => {
    // In a production app with real file uploads, this would download the actual file
    // For now, we'll show an informational message
    toast({
      title: 'File Information',
      description: `File "${fileName}" would be downloaded from storage. Students uploaded this file with their submission.`,
    });
  };

  const viewFileInfo = (file: { name: string; type: string }) => {
    setSelectedFile(file);
    toast({ description: `Viewing file: ${file.name}` });
  };

  const getGrade = (marks?: number) => {
    if (!marks) return '-';
    if (marks >= 90) return 'A';
    if (marks >= 80) return 'B';
    if (marks >= 70) return 'C';
    if (marks >= 60) return 'D';
    return 'F';
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-white to-gray-50">
      {/* Header */}
      <div className="bg-gradient-green shadow-sm">
        <div className="max-w-7xl mx-auto px-4 py-6 md:py-8 flex items-center justify-between">
          <div>
            <h1 className="text-3xl font-bold text-white">Assignment Submissions</h1>
            <p className="text-white/80 text-sm mt-1">Instructor: {user.username}</p>
          </div>
          <button
            onClick={handleLogout}
            className="flex items-center gap-2 bg-white/20 hover:bg-white/30 text-white px-4 py-2 rounded-lg transition-colors duration-200"
          >
            <LogOut className="w-4 h-4" />
            <span className="text-sm font-medium">Logout</span>
          </button>
        </div>
      </div>

      {/* Main Content */}
      <div className="max-w-7xl mx-auto px-4 py-12">
        {submissions.length === 0 ? (
          <div className="bg-white rounded-2xl shadow-xl p-12 text-center">
            <MessageSquare className="w-16 h-16 text-gray-300 mx-auto mb-4" />
            <h2 className="text-2xl font-semibold text-gray-700 mb-2">No Submissions Yet</h2>
            <p className="text-gray-600">
              Students will be able to submit their assignments here
            </p>
          </div>
        ) : (
          <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
            {/* Submissions List */}
            <div className="lg:col-span-1">
              <div className="bg-white rounded-2xl shadow-xl overflow-hidden">
                <div className="bg-gradient-to-r from-green-50 to-emerald-50 p-4 border-b border-gray-200">
                  <h3 className="font-semibold text-gray-900">
                    {submissions.length} Submission{submissions.length !== 1 ? 's' : ''}
                  </h3>
                </div>
                <div className="divide-y max-h-96 overflow-y-auto">
                  {submissions.map((submission) => (
                    <button
                      key={submission.id}
                      onClick={() => handleSubmissionSelect(submission)}
                      className={`w-full p-4 text-left hover:bg-gray-50 transition-colors ${
                        selectedSubmission?.id === submission.id ? 'bg-green-50 border-l-4 border-primary' : ''
                      }`}
                    >
                      <p className="font-semibold text-gray-900">{submission.studentName}</p>
                      <p className="text-xs text-gray-500 mt-1">{submission.studentEmail}</p>
                      <div className="flex items-center justify-between mt-2">
                        <span className="text-xs text-gray-600">
                          {submission.files.length} file{submission.files.length !== 1 ? 's' : ''}
                        </span>
                        {submission.marks !== undefined && (
                          <span className="text-sm font-semibold text-primary">
                            {submission.marks}/100
                          </span>
                        )}
                      </div>
                    </button>
                  ))}
                </div>
              </div>
            </div>

            {/* Submission Details & Grading */}
            {selectedSubmission && (
              <div className="lg:col-span-2 space-y-6">
                {/* Student Info */}
                <div className="bg-white rounded-2xl shadow-xl p-8">
                  <h3 className="text-xl font-semibold text-gray-900 mb-4">Student Information</h3>
                  <div className="space-y-3">
                    <div>
                      <p className="text-sm text-gray-600">Student Name</p>
                      <p className="text-lg font-semibold text-gray-900">{selectedSubmission.studentName}</p>
                    </div>
                    <div>
                      <p className="text-sm text-gray-600">Email</p>
                      <p className="text-gray-900">{selectedSubmission.studentEmail}</p>
                    </div>
                    <div>
                      <p className="text-sm text-gray-600">Submitted</p>
                      <p className="text-gray-900">
                        {new Date(selectedSubmission.submittedAt).toLocaleString()}
                      </p>
                    </div>
                  </div>

                  {/* Files and Links */}
                  <div className="mt-6 pt-6 border-t border-gray-200 space-y-6">
                    {selectedSubmission.files && selectedSubmission.files.length > 0 && (
                      <div>
                        <h4 className="font-semibold text-gray-900 mb-3">Submitted Files ({selectedSubmission.files.length})</h4>
                        <div className="space-y-2">
                          {selectedSubmission.files.map((file, idx) => (
                            <div key={idx} className="flex items-center gap-3 p-3 bg-blue-50 rounded-lg border border-blue-200 hover:bg-blue-100 transition-colors">
                              <FileText className="w-4 h-4 text-blue-600 flex-shrink-0" />
                              <div className="flex-1 min-w-0">
                                <p className="text-sm font-medium text-gray-900 truncate">{file.name}</p>
                                <p className="text-xs text-gray-600">{file.type}</p>
                              </div>
                              <button
                                onClick={() => downloadFile(file.name)}
                                className="flex items-center gap-1 text-blue-600 hover:text-blue-800 text-sm font-medium transition-colors"
                              >
                                <Download className="w-4 h-4" />
                                Download
                              </button>
                            </div>
                          ))}
                        </div>
                        <div className="mt-3 p-3 bg-blue-50 border border-blue-200 rounded-lg flex gap-2">
                          <AlertCircle className="w-4 h-4 text-blue-600 flex-shrink-0 mt-0.5" />
                          <p className="text-xs text-blue-800">Files uploaded by students are stored securely. Click Download to view or save each submission file.</p>
                        </div>
                      </div>
                    )}

                    {selectedSubmission.links && selectedSubmission.links.length > 0 && (
                      <div>
                        <h4 className="font-semibold text-gray-900 mb-3">Submitted Links ({selectedSubmission.links.length})</h4>
                        <div className="space-y-2">
                          {selectedSubmission.links.map((link, idx) => (
                            <a
                              key={idx}
                              href={link.url}
                              target="_blank"
                              rel="noopener noreferrer"
                              className="flex items-center gap-3 p-3 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors border border-blue-200"
                            >
                              <LinkIcon className="w-4 h-4 text-blue-600 flex-shrink-0" />
                              <div className="flex-1 min-w-0">
                                <p className="text-sm font-medium text-gray-900">{link.title}</p>
                                <p className="text-xs text-blue-600 truncate">{link.url}</p>
                              </div>
                            </a>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                </div>

                {/* Grading Form */}
                <div className="bg-white rounded-2xl shadow-xl p-8">
                  <h3 className="text-xl font-semibold text-gray-900 mb-6">Grade & Feedback</h3>
                  <div className="space-y-5">
                    <div>
                      <label htmlFor="marks" className="block text-sm font-semibold text-gray-700 mb-2">
                        Marks (0-100)
                      </label>
                      <input
                        id="marks"
                        type="number"
                        min="0"
                        max="100"
                        value={marks}
                        onChange={(e) => setMarks(e.target.value)}
                        placeholder="Enter marks"
                        className="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
                      />
                      {marks && !isNaN(parseInt(marks)) && (
                        <div className="mt-3 p-3 bg-green-50 border border-green-200 rounded-lg flex items-center justify-between">
                          <span className="text-sm font-semibold text-gray-700">Grade</span>
                          <span className="text-2xl font-bold text-primary">
                            {getGrade(parseInt(marks))}
                          </span>
                        </div>
                      )}
                    </div>

                    <div>
                      <label htmlFor="feedback" className="block text-sm font-semibold text-gray-700 mb-2">
                        Feedback
                      </label>
                      <textarea
                        id="feedback"
                        value={feedback}
                        onChange={(e) => setFeedback(e.target.value)}
                        placeholder="Add feedback for the student..."
                        rows={5}
                        className="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition resize-none"
                      ></textarea>
                    </div>

                    <button
                      onClick={handleSaveMarks}
                      disabled={isSaving || !marks}
                      className="w-full flex items-center justify-center gap-2 bg-gradient-green text-white font-semibold py-3 rounded-lg hover:shadow-lg transition-all duration-300 disabled:opacity-50"
                    >
                      <Save className="w-4 h-4" />
                      {isSaving ? 'Saving...' : 'Save Marks & Feedback'}
                    </button>
                  </div>
                </div>
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  );
}
